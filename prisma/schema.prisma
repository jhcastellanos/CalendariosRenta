generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  cleaning
}

enum ReservationStatus {
  active
  canceled
}

enum CleaningStatus {
  pending
  completed
  canceled
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(admin)
  createdAt    DateTime @default(now())
}

model Property {
  id        String           @id @default(cuid())
  title     String
  photoUrl  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  sources   CalendarSource[]
  reservations Reservation[]
  cleanings Cleaning[]
}

model CalendarSource {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  sourceType SourceType
  icalUrl    String
  color      String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reservations Reservation[]
  syncLogs   SyncLog[]
}

enum SourceType {
  airbnb
  vrbo
}

model Reservation {
  id            String            @id @default(cuid())
  property      Property          @relation(fields: [propertyId], references: [id])
  propertyId    String
  calendarSource CalendarSource  @relation(fields: [calendarSourceId], references: [id])
  calendarSourceId String
  sourceType    SourceType
  externalUid   String
  checkInDate   DateTime
  checkOutDate  DateTime
  guestName     String?
  status        ReservationStatus @default(active)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  cleanings     Cleaning[]

  @@unique([calendarSourceId, externalUid])
}

model Cleaning {
  id             String         @id @default(cuid())
  property       Property       @relation(fields: [propertyId], references: [id])
  propertyId     String
  reservation    Reservation    @relation(fields: [reservationId], references: [id])
  reservationId  String
  cleaningDate   DateTime
  status         CleaningStatus @default(pending)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model SyncLog {
  id            String      @id @default(cuid())
  calendarSource CalendarSource @relation(fields: [calendarSourceId], references: [id])
  calendarSourceId String
  success       Boolean
  message       String?
  syncedAt      DateTime    @default(now())
}
